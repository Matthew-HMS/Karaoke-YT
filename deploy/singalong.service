# systemd unit to keep SingAlong running on the VM and restart it on crash/boot.
# Install:
#   sudo cp deploy/singalong.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now singalong
# View logs:  journalctl -u singalong -f
#
# Adjust User, WorkingDirectory, and the YOUTUBE_API_KEY below for your VM.

[Unit]
Description=SingAlong karaoke server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/karaoke
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=DB_PATH=/home/ubuntu/karaoke/singalong.db
Environment=YOUTUBE_API_KEY=replace-with-your-key
# Google sign-in (Auth.js). AUTH_URL must be your public HTTPS domain so the
# OAuth callback is correct behind Caddy.
Environment=AUTH_SECRET=replace-with-openssl-rand-base64-32
Environment=AUTH_GOOGLE_ID=replace-with-client-id
Environment=AUTH_GOOGLE_SECRET=replace-with-client-secret
Environment=AUTH_URL=https://your-subdomain.duckdns.org
# Build once before starting (npm run build), then this runs the prod server.
ExecStart=/usr/bin/npm run start
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
